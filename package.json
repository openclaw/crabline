{
  "name": "@openclaw/crabline",
  "version": "0.1.9",
  "description": "Standalone CLI for deterministic messaging provider E2E tests",
  "homepage": "https://github.com/openclaw/crabline#readme",
  "bugs": {
    "url": "https://github.com/openclaw/crabline/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/crabline"
  },
  "bin": {
    "crabline": "dist/src/bin/crabline.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "docs/channel-setup.md",
    "fixtures"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"const fs = require('node:fs'); for (const path of ['dist', 'coverage']) fs.rmSync(path, { recursive: true, force: true })\"",
    "dev": "tsx src/bin/crabline.ts",
    "doctor": "tsx src/bin/crabline.ts doctor",
    "fixtures": "tsx src/bin/crabline.ts fixtures",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm format:check && pnpm typecheck && oxlint --deny-warnings --allow vitest/require-mock-type-parameters --type-aware --tsconfig tsconfig.test.json src test",
    "prepare": "npm run build",
    "run": "tsx src/bin/crabline.ts run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json",
    "verify": "pnpm lint && pnpm test:coverage",
    "check": "pnpm verify"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "curve25519-js": "^0.0.4",
    "picocolors": "^1.1.1",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "baileys": "7.0.0-rc13",
    "matrix-js-sdk": "41.9.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
